# Copy this file to .env before running:
#
#   docker compose --env-file .env -f compose.yml up -d
#
# Use strong random values for every secret in production.

# Public HTTPS hosts.
APP_HOST=draw.example.com
ROOM_HOST=draw.example.com
STORAGE_BACKEND_HOST=draw.example.com/storage

# OSS explicit-save wrapper route.
EDITOR_OPEN_PATH=/editor/

# MongoDB used by the existing Excalidraw storage backend.
DB_USER=mydbuser
DB_PASS=change-me-mongodb-password
DB_VOLUME_PATH=./mongo-data

# OSS file gateway.
#
# TOKEN_SECRET signs browser access tokens.
# HOST_API_KEY is used by your host app to create editor sessions.
TOKEN_SECRET=change-me-to-a-long-random-token-secret
HOST_API_KEY=change-me-host-api-key
TOKEN_TTL_SECONDS=3600
ALLOWED_ORIGINS=https://draw.example.com,http://localhost:9017
MAX_BODY_BYTES=10485760
LOCK_TTL_SECONDS=1800

# File storage adapter.
#
# filesystem = store .excalidraw files in FILE_STORAGE_PATH.
# http = call your DMS through HOST_STORAGE_BASE_URL.
STORAGE_ADAPTER=filesystem
FILE_STORAGE_PATH=./file-data
HOST_STORAGE_BASE_URL=https://dms.example.com/oss
HOST_STORAGE_API_KEY=change-me-dms-api-key
